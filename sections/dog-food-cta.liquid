{%- comment -%}
  Shopify Section: Dog Food CTA & Trust Banner
  File: sections/dog-food-cta.liquid
  Description: Center-aligned call-to-action banner with guarantee shield and checkout payment options.
{%- endcomment -%}

<div class="df-cta-container" id="DfCta-{{ section.id }}">
  <div class="df-cta-inner">
    
    <!-- CTA Title -->
    <h2 class="df-cta-title">
      {{ section.settings.heading | default: "Get your dog's healthy meal today!" }}
    </h2>

    <!-- CTA Button -->
    {%- if section.settings.button_label != blank and section.settings.button_link != blank -%}
      <div class="df-cta-action-box">
        <a href="{{ section.settings.button_link }}" class="df-cta-button">
          {{ section.settings.button_label }}
        </a>
      </div>
    {%- endif -%}

    <!-- Trust Row (Guarantee Shield + Payments) -->
    <div class="df-trust-row">
      <div class="df-guarantee-badge">
        <svg class="df-shield-icon" viewBox="0 0 24 24" width="15" height="15" stroke="currentColor" stroke-width="2.5" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 11 11 13 15 9"/></svg>
        <span class="df-trust-text">
          {{ section.settings.guarantee_text | default: "30-day money back guarantee" }}
        </span>
      </div>

      <div class="df-payment-logos">
        <img src="./assets/paypal_icon.png" alt="Paypal">
        <img src="./assets/visa_icon.png" alt="Visa">
        <img src="./assets/mastercard_icon.png" alt="Mastercard">
        <img src="./assets/apple_pay_icon.png" alt="Apple Pay">
        <img src="./assets/gpay_icon.png" alt="GPay">
      </div>
    </div>

  </div>
</div>

<style>
  .df-cta-container {
    padding: 72px 24px;
    background-color: #fcfbf7;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  }

  .df-cta-inner {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .df-cta-title {
    font-size: 34px;
    font-weight: 850;
    color: var(--df-dark);
    margin: 0 0 28px 0;
    letter-spacing: -0.8px;
    line-height: 1.2;
    max-width: 540px;
    text-align: center;
  }

  @media (max-width: 768px) {
    .df-cta-title {
      font-size: 26px;
      margin-bottom: 24px;
    }
  }

  .df-cta-action-box {
    margin-bottom: 0px; /* Reset margin since gap is handled by df-trust-row margin */
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .df-cta-button {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 462px;
    height: 56px;
    background-color: var(--df-primary);
    color: #ffffff;
    font-family: 'Outfit', sans-serif;
    font-weight: 750;
    font-size: 15px;
    border-radius: 24px; /* pill shape */
    text-decoration: none;
    text-align: center;
    box-sizing: border-box;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow: 0 4px 10px rgba(21, 128, 61, 0.2);
  }

  .df-cta-button:hover {
    background-color: #166534;
    transform: translateY(-1px);
    box-shadow: 0 8px 16px rgba(21, 128, 61, 0.3);
  }

  /* Trust row styling (Exactly 462px wide with 16px gap) */
  .df-trust-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 462px;
    margin-top: 16px; /* Exactly 16px gap */
    box-sizing: border-box;
    padding: 0 4px;
  }

  @media (max-width: 500px) {
    .df-cta-button {
      width: 100%;
      max-width: 462px;
    }
    .df-trust-row {
      width: 100%;
      max-width: 462px;
      flex-direction: column;
      gap: 12px;
      text-align: center;
    }
  }

  .df-guarantee-badge {
    display: flex;
    align-items: center;
    gap: 6px;
    color: var(--df-gray);
  }

  .df-shield-icon {
    color: var(--df-gray);
    flex-shrink: 0;
  }

  .df-trust-text {
    font-size: 13.5px;
    font-weight: 500;
    color: var(--df-gray);
    text-transform: none; /* normal capitalization matching figma */
  }

  .df-payment-logos {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .df-payment-logos img {
    height: 18px;
    width: auto;
    object-fit: contain;
    opacity: 0.8;
  }
</style>

{% schema %}
{
  "name": "Dog Food CTA",
  "tag": "section",
  "class": "section-df-cta",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "CTA Heading",
      "default": "Get your dog's healthy meal today!"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Order Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link",
      "default": "/collections/all"
    },
    {
      "type": "text",
      "id": "guarantee_text",
      "label": "Guarantee Text",
      "default": "30-day money back guarantee"
    }
  ],
  "presets": [
    {
      "name": "Dog Food CTA"
    }
  ]
}
{% endschema %}
