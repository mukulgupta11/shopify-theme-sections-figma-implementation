    },
    {
      "type": "textarea",
      "id": "f2_desc",
      "label": "Feature 2 Description",
      "default": "Elevating pet care with unmatched safety and quality."
    },
    {
      "type": "text",
      "id": "f3_title",
      "label": "Feature 3 Title",
      "default": "Made Fresh"
    },
    {
