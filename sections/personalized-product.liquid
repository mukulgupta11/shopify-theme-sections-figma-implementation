{%- comment -%}
  Shopify Section: Personalized Product with POD Options
  File: sections/personalized-product.liquid
  Description: Custom section for Print-on-Demand products with slogan text, image uploader, swatches, quantity selectors, trust badges, and tab details.
{%- endcomment -%}

{%- liquid
  assign current_product = product | default: all_products.first
  assign current_variant = current_product.selected_or_first_available_variant

  assign title = current_product.title | default: "Personalized Photo and Slogan Text Hoodie"
  assign price = current_variant.price | default: 7999
  assign compare_at_price = current_variant.compare_at_price | default: 9999
  assign description = current_product.description | default: "Express the unique relationship between you and your loved ones in a custom printed hoodie."
  assign vendor = current_product.vendor | default: "Always Way Sportswear"
-%}

<div class="pod-product-container" id="PodSection-{{ section.id }}">
  <div class="pod-product-grid">
    
    <!-- LEFT COLUMN: Image Gallery -->
    <div class="pod-gallery-column">
      <div class="pod-main-image-wrapper">
        {%- if current_variant.featured_image -%}
          <img id="PodMainImage-{{ section.id }}" class="pod-main-image" src="{{ current_variant.featured_image | image_url: width: 800 }}" alt="{{ title }}" width="800" height="800" loading="eager">
        {%- elsif current_product.featured_image -%}
          <img id="PodMainImage-{{ section.id }}" class="pod-main-image" src="{{ current_product.featured_image | image_url: width: 800 }}" alt="{{ title }}" width="800" height="800" loading="eager">
        {%- else -%}
          <!-- Placeholder Hoodie Image -->
          <img id="PodMainImage-{{ section.id }}" class="pod-main-image" src="https://images.unsplash.com/photo-1556821840-3a63f95609a7?auto=format&fit=crop&w=800&q=80" alt="Personalized Hoodie" width="800" height="800" loading="eager">
        {%- endif -%}
        
        {%- if compare_at_price > price -%}
          <span class="pod-discount-tag">-{{ compare_at_price | minus: price | times: 100.0 | divided_by: compare_at_price | round }}% OFF</span>
        {%- endif -%}
      </div>
      
      <!-- Thumbnails -->
      <div class="pod-thumbnails-grid">
        {%- if current_product.images.size > 0 -%}
          {%- for image in current_product.images limit: 4 -%}
            <button class="pod-thumbnail-btn {% if forloop.first %}active{% endif %}" data-image-url="{{ image | image_url: width: 800 }}" aria-label="View product image {{ forloop.index }}">
              <img src="{{ image | image_url: width: 120 }}" alt="{{ image.alt | escape }}" width="120" height="120" loading="lazy">
            </button>
          {%- endfor -%}
        {%- else -%}
          <!-- Fallback Placeholders -->
          <button class="pod-thumbnail-btn active" data-image-url="https://images.unsplash.com/photo-1556821840-3a63f95609a7?auto=format&fit=crop&w=800&q=80" aria-label="View image 1">
            <img src="https://images.unsplash.com/photo-1556821840-3a63f95609a7?auto=format&fit=crop&w=120&q=80" alt="Hoodie front" width="120" height="120" loading="lazy">
          </button>
          <button class="pod-thumbnail-btn" data-image-url="https://images.unsplash.com/photo-1556911220-e15b29be8c8f?auto=format&fit=crop&w=800&q=80" aria-label="View image 2">
            <img src="https://images.unsplash.com/photo-1556911220-e15b29be8c8f?auto=format&fit=crop&w=120&q=80" alt="Hoodie model" width="120" height="120" loading="lazy">
          </button>
          <button class="pod-thumbnail-btn" data-image-url="https://images.unsplash.com/photo-1620799140408-edc6dcb6d633?auto=format&fit=crop&w=800&q=80" aria-label="View image 3">
            <img src="https://images.unsplash.com/photo-1620799140408-edc6dcb6d633?auto=format&fit=crop&w=120&q=80" alt="Hoodie folded" width="120" height="120" loading="lazy">
          </button>
        {%- endif -%}
      </div>
    </div>

    <!-- RIGHT COLUMN: Product Form & Info -->
    <div class="pod-details-column">
      <span class="pod-brand-tag">{{ vendor }}</span>
      <h1 class="pod-product-title">{{ title }}</h1>

      <!-- Rating and Price Row -->
      <div class="pod-meta-row">
        <div class="pod-stars-rating">
          <span class="pod-stars">★★★★★</span>
          <span class="pod-reviews-count">(8 reviews)</span>
        </div>
        <div class="pod-price-box">
          <span id="PodProductPrice-{{ section.id }}" class="pod-current-price">{{ price | money }}</span>
          {%- if compare_at_price > price -%}
            <span id="PodComparePrice-{{ section.id }}" class="pod-compare-price">{{ compare_at_price | money }}</span>
          {%- endif -%}
        </div>
      </div>

      <div class="pod-divider"></div>
      <p class="pod-product-description">{{ description }}</p>

      <!-- Cart / Product Form -->
      {%- form 'product', current_product, id: 'PodProductForm', class: 'pod-product-form' -%}
        
        <!-- Hidden input for Shopify variant submission -->
        <input type="hidden" name="id" id="PodSelectedVariantId-{{ section.id }}" value="{{ current_variant.id }}">

        <!-- COLOR SWATCHES -->
        <div class="pod-option-group">
          <label class="pod-option-label">Color: <span id="SelectedColorText" class="pod-selected-text-val">White</span></label>
          <div class="pod-swatch-list">
            <button type="button" class="pod-swatch-btn active" data-color="White" style="background-color: #ffffff;" aria-label="White Color Swatch"></button>
            <button type="button" class="pod-swatch-btn" data-color="Black" style="background-color: #1a1a1a;" aria-label="Black Color Swatch"></button>
            <button type="button" class="pod-swatch-btn" data-color="Navy" style="background-color: #1e3a8a;" aria-label="Navy Color Swatch"></button>
            <button type="button" class="pod-swatch-btn" data-color="Royal Blue" style="background-color: #3b82f6;" aria-label="Royal Blue Color Swatch"></button>
            <button type="button" class="pod-swatch-btn" data-color="Sand" style="background-color: #d7ccc8;" aria-label="Sand Color Swatch"></button>
          </div>
        </div>

        <!-- SIZE SELECTORS -->
        <div class="pod-option-group">
          <label class="pod-option-label">Size: <span id="SelectedSizeText" class="pod-selected-text-val">L</span></label>
          <div class="pod-size-list">
            <button type="button" class="pod-size-pill" data-size="S">S</button>
            <button type="button" class="pod-size-pill" data-size="M">M</button>
            <button type="button" class="pod-size-pill active" data-size="L">L</button>
            <button type="button" class="pod-size-pill" data-size="XL">XL</button>
            <button type="button" class="pod-size-pill" data-size="2XL">2XL</button>
          </div>
        </div>

        <!-- CUSTOM PERSONALIZATION OPTIONS (Line Item Properties) -->
        <div class="pod-personalization-card">
          <div class="pod-personalization-title">
            <svg class="pod-sparkle-icon" viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
            Personalization Options
          </div>
          
          <!-- Slogan Text Box -->
          <div class="pod-field-group">
            <div class="pod-field-header">
              <label for="PersonalizationSlogan" class="pod-field-label">Enter your slogan <span class="pod-optional-tag">(+$2.00 for custom text)</span></label>
              <span id="SloganCharCount" class="pod-char-counter">0/25</span>
            </div>
            <input type="text" 
                   id="PersonalizationSlogan" 
                   name="properties[Slogan]" 
                   class="pod-text-input" 
                   placeholder="e.g. Always way, Fit, Together" 
                   maxlength="25"
                   autocomplete="off">
          </div>

          <!-- Photo Image Uploader -->
          <div class="pod-field-group">
            <label class="pod-field-label">Upload your photo <span class="pod-required-star">*</span></label>
            <div class="pod-upload-area" id="PodUploadContainer">
              <input type="file" 
                     id="PersonalizationPhoto" 
                     name="properties[Photo]" 
                     class="pod-file-input" 
                     accept="image/*">
              <label for="PersonalizationPhoto" class="pod-upload-trigger">
                <svg class="pod-upload-icon" viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
                <span class="pod-upload-main-text">Choose file or drag here</span>
                <span class="pod-upload-sub-text">PNG, JPG, or JPEG up to 10MB</span>
              </label>
            </div>
            <!-- File Preview Area -->
            <div class="pod-file-preview-card" id="FilePreviewCard" style="display: none;">
              <img id="FilePreviewImage" class="pod-file-preview-img" src="" alt="Photo preview" width="40" height="40">
              <div class="pod-file-preview-info">
                <span id="FilePreviewName" class="pod-file-name">filename.jpg</span>
                <span id="FilePreviewSize" class="pod-file-size">1.2 MB</span>
              </div>
              <button type="button" class="pod-file-remove-btn" id="RemoveFileBtn" aria-label="Remove uploaded photo">✕</button>
            </div>
          </div>
        </div>

        <!-- QUANTITY & BUTTON ACTIONS -->
        <div class="pod-actions-row">
          <div class="pod-quantity-selector">
            <button type="button" class="pod-qty-btn" id="QtyMinus" aria-label="Decrease quantity">−</button>
            <input type="number" id="PodQuantity" name="quantity" class="pod-qty-input" value="1" min="1" readonly>
            <button type="button" class="pod-qty-btn" id="QtyPlus" aria-label="Increase quantity">+</button>
          </div>
          <button type="submit" class="pod-submit-btn" id="PodAddToCartBtn">
            <span class="pod-btn-text">GET MY DESIGN</span>
            <span class="pod-btn-spinner" style="display: none;"></span>
          </button>
        </div>

      {%- endform -%}

      <!-- TRUST BADGES -->
      <div class="pod-badges-grid">
        <div class="pod-badge-item">
          <svg viewBox="0 0 24 24" width="20" height="20" stroke="#4f46e5" stroke-width="2" fill="none"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
          <div class="pod-badge-text-box">
            <span class="pod-badge-title">Free Shipping</span>
            <span class="pod-badge-desc">On orders over $50</span>
          </div>
        </div>
        <div class="pod-badge-item">
          <svg viewBox="0 0 24 24" width="20" height="20" stroke="#4f46e5" stroke-width="2" fill="none"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
          <div class="pod-badge-text-box">
            <span class="pod-badge-title">Secure Checkout</span>
            <span class="pod-badge-desc">Guaranteed safe payment</span>
          </div>
        </div>
        <div class="pod-badge-item">
          <svg viewBox="0 0 24 24" width="20" height="20" stroke="#4f46e5" stroke-width="2" fill="none"><path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.57-8.38l5.67-5.67"/></svg>
          <div class="pod-badge-text-box">
            <span class="pod-badge-title">Easy 30-Day Returns</span>
            <span class="pod-badge-desc">Hassle-free guarantee</span>
          </div>
        </div>
      </div>

      <!-- TABS ACCORDION -->
      <div class="pod-tabs-container">
        <div class="pod-tabs-header">
          <button type="button" class="pod-tab-header-btn active" data-tab="overview">OVERVIEW</button>
          <button type="button" class="pod-tab-header-btn" data-tab="sizing">SIZING</button>
          <button type="button" class="pod-tab-header-btn" data-tab="packaging">PACKAGING</button>
          <button type="button" class="pod-tab-header-btn" data-tab="shipping">SHIPPING</button>
        </div>
        <div class="pod-tabs-body">
          <!-- Overview Tab -->
          <div class="pod-tab-content active" id="Tab-overview">
            <ul class="pod-info-list">
              <li><strong>Description:</strong> {{ description }}</li>
              <li><strong>Material:</strong> 80% Organic Cotton, 20% Recycled Polyester fleece for ultimate comfort.</li>
              <li><strong>Weight:</strong> Heavyweight fabric (280 gsm / 8.3 oz).</li>
              <li><strong>Details:</strong> Front pouch pocket, dual-ply hoodie, metal grommets with premium matching drawcords.</li>
            </ul>
          </div>
          <!-- Sizing Tab -->
          <div class="pod-tab-content" id="Tab-sizing">
            <div class="pod-sizing-grid">
              <div class="pod-sizing-chart-img">
                <!-- Hoodie drawing svg -->
                <svg viewBox="0 0 120 120" width="100" height="100" class="pod-sizing-svg" fill="none" stroke="#6b7280" stroke-width="1.5">
                  <path d="M35 15h50M35 15C32 20 22 25 15 30l8 12 12-5v68h50V37l12 5 8-12C98 25 88 20 85 15"/>
                  <path d="M50 15c0 10 20 10 20 0M35 30h50M50 15v10m20-10v10"/>
                  <!-- Sizing lines -->
                  <path stroke="#4f46e5" stroke-dasharray="3,3" d="M35 45h50M35 37v68"/>
                </svg>
              </div>
              <table class="pod-sizing-table">
                <thead>
                  <tr>
                    <th>Size</th>
                    <th>Width (in)</th>
                    <th>Length (in)</th>
                    <th>Sleeve (in)</th>
                  </tr>
                </thead>
                <tbody>
                  <tr><td>S</td><td>20"</td><td>27"</td><td>33"</td></tr>
                  <tr><td>M</td><td>22"</td><td>28"</td><td>34"</td></tr>
                  <tr><td>L</td><td>24"</td><td>29"</td><td>35"</td></tr>
                  <tr><td>XL</td><td>26"</td><td>30"</td><td>36"</td></tr>
                  <tr><td>2XL</td><td>28"</td><td>31"</td><td>37"</td></tr>
                </tbody>
              </table>
            </div>
          </div>
          <!-- Packaging Tab -->
          <div class="pod-tab-content" id="Tab-packaging">
            <p class="pod-tab-para">
              Each custom-printed hoodie is carefully folded and packaged in a <strong>durable, waterproof protective mailing bag</strong>. This ensures your customized print and fabric arrive in pristine condition, ready to wear or gift to your loved ones.
            </p>
          </div>
          <!-- Shipping Tab -->
          <div class="pod-tab-content" id="Tab-shipping">
            <p class="pod-tab-para">
              Since all orders are custom-printed on demand, please allow <strong>2-3 business days</strong> for production before shipping. 
            </p>
            <ul class="pod-info-list">
              <li><strong>Standard Shipping:</strong> 3-5 business days (Free on orders over $50).</li>
              <li><strong>Express Shipping:</strong> 1-2 business days with tracking info provided via email.</li>
            </ul>
          </div>
        </div>
      </div>

    </div>

  </div>
</div>

<style>
  /* CSS STYLES FOR THE CUSTOM POD PRODUCT SECTION */
  :root {
    --pod-primary: #4f46e5;
    --pod-primary-hover: #4338ca;
    --pod-dark: #0f172a;
    --pod-light: #f8fafc;
    --pod-border: #e2e8f0;
    --pod-gray: #64748b;
    --pod-white: #ffffff;
    --pod-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.05), 0 4px 6px -4px rgb(0 0 0 / 0.05);
    --pod-radius-sm: 6px;
    --pod-radius-md: 12px;
    --pod-radius-lg: 16px;
  }

  .pod-product-container {
    max-width: 1200px;
    margin: 40px auto;
    padding: 0 24px;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    color: var(--pod-dark);
    line-height: 1.5;
  }

  .pod-product-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 48px;
    align-items: start;
  }

  @media (max-width: 991px) {
    .pod-product-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }

  /* LEFT GALLERY STYLE */
  .pod-gallery-column {
    display: flex;
    flex-direction: column;
    gap: 16px;
    position: sticky;
    top: 20px;
  }

  .pod-main-image-wrapper {
    position: relative;
    border-radius: var(--pod-radius-lg);
    overflow: hidden;
    background-color: var(--pod-light);
    aspect-ratio: 1 / 1;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--pod-border);
  }

  .pod-main-image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .pod-main-image:hover {
    transform: scale(1.05);
  }

  .pod-discount-tag {
    position: absolute;
    top: 16px;
    right: 16px;
    background-color: #ef4444;
    color: var(--pod-white);
    font-weight: 700;
    font-size: 12px;
    padding: 6px 12px;
    border-radius: 9999px;
    letter-spacing: 0.5px;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
  }

  .pod-thumbnails-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
  }

  .pod-thumbnail-btn {
    border-radius: var(--pod-radius-md);
    border: 2px solid transparent;
    overflow: hidden;
    background: var(--pod-light);
    aspect-ratio: 1 / 1;
    cursor: pointer;
    padding: 0;
    transition: all 0.2s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .pod-thumbnail-btn img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .pod-thumbnail-btn:hover {
    transform: translateY(-2px);
  }

  .pod-thumbnail-btn.active {
    border-color: var(--pod-primary);
    box-shadow: 0 4px 6px -1px rgba(79, 70, 229, 0.15);
  }

  /* RIGHT PRODUCT DETAIL STYLE */
  .pod-brand-tag {
    font-size: 13px;
    text-transform: uppercase;
    font-weight: 600;
    letter-spacing: 1.5px;
    color: var(--pod-primary);
    display: block;
    margin-bottom: 8px;
  }

  .pod-product-title {
    font-size: 32px;
    font-weight: 800;
    letter-spacing: -0.5px;
    margin: 0 0 16px 0;
    color: var(--pod-dark);
  }

  @media (max-width: 768px) {
    .pod-product-title {
      font-size: 26px;
    }
  }

  .pod-meta-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
  }

  .pod-stars-rating {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .pod-stars {
    color: #fbbf24;
    font-size: 16px;
    letter-spacing: 1px;
  }

  .pod-reviews-count {
    color: var(--pod-gray);
    font-size: 14px;
    font-weight: 500;
  }

  .pod-price-box {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .pod-current-price {
    font-size: 24px;
    font-weight: 800;
    color: var(--pod-primary);
  }

  .pod-compare-price {
    font-size: 16px;
    text-decoration: line-through;
    color: var(--pod-gray);
  }

  .pod-divider {
    height: 1px;
    background-color: var(--pod-border);
    margin: 16px 0;
  }

  .pod-product-description {
    font-size: 15px;
    color: var(--pod-gray);
    margin-bottom: 24px;
  }

  /* OPTION SWATCHES & SELECTORS */
  .pod-option-group {
    margin-bottom: 20px;
  }

  .pod-option-label {
    font-size: 14px;
    font-weight: 600;
    color: var(--pod-dark);
    margin-bottom: 8px;
    display: block;
  }

  .pod-selected-text-val {
    color: var(--pod-gray);
    font-weight: 500;
  }

  .pod-swatch-list {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .pod-swatch-btn {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 1px solid var(--pod-border);
    cursor: pointer;
    position: relative;
    padding: 0;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .pod-swatch-btn:hover {
    transform: scale(1.15);
  }

  .pod-swatch-btn::after {
    content: '';
    position: absolute;
    inset: -4px;
    border: 2px solid transparent;
    border-radius: 50%;
    transition: all 0.2s ease;
  }

  .pod-swatch-btn.active::after {
    border-color: var(--pod-primary);
  }

  .pod-swatch-btn[data-color="White"] {
    border: 1px solid #cbd5e1; /* White border outline */
  }

  .pod-size-list {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .pod-size-pill {
    min-width: 44px;
    height: 38px;
    border: 1.5px solid var(--pod-border);
    background-color: var(--pod-white);
    border-radius: var(--pod-radius-sm);
    font-size: 13px;
    font-weight: 600;
    color: var(--pod-dark);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 12px;
    transition: all 0.2s ease;
  }

  .pod-size-pill:hover {
    border-color: var(--pod-gray);
  }

  .pod-size-pill.active {
    border-color: var(--pod-primary);
    background-color: var(--pod-light);
    color: var(--pod-primary);
  }

  /* PERSONALIZATION CARD */
  .pod-personalization-card {
    border: 1.5px dashed var(--pod-primary);
    border-radius: var(--pod-radius-md);
    padding: 20px;
    margin-bottom: 24px;
    background-color: #f5f3ff; /* light purple background */
  }

  .pod-personalization-title {
    font-size: 15px;
    font-weight: 700;
    color: var(--pod-primary);
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 16px;
  }

  .pod-sparkle-icon {
    color: var(--pod-primary);
  }

  .pod-field-group {
    margin-bottom: 16px;
  }

  .pod-field-group:last-child {
    margin-bottom: 0;
  }

  .pod-field-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 6px;
  }

  .pod-field-label {
    font-size: 13px;
    font-weight: 600;
    color: var(--pod-dark);
  }

  .pod-optional-tag {
    font-size: 11px;
    color: var(--pod-primary);
    font-weight: 500;
  }

  .pod-required-star {
    color: #ef4444;
    font-weight: 700;
  }

  .pod-char-counter {
    font-size: 11px;
    color: var(--pod-gray);
  }

  .pod-text-input {
    width: 100%;
    height: 42px;
    border: 1px solid var(--pod-border);
    border-radius: var(--pod-radius-sm);
    padding: 0 14px;
    font-size: 13px;
    color: var(--pod-dark);
    box-sizing: border-box;
    transition: all 0.2s ease;
    background-color: var(--pod-white);
  }

  .pod-text-input:focus {
    outline: none;
    border-color: var(--pod-primary);
    box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.1);
  }

  /* PHOTO UPLOAD AREA */
  .pod-upload-area {
    position: relative;
    border: 1px dashed var(--pod-border);
    border-radius: var(--pod-radius-sm);
    background-color: var(--pod-white);
    padding: 16px;
    text-align: center;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .pod-upload-area:hover {
    border-color: var(--pod-primary);
    background-color: var(--pod-light);
  }

  .pod-file-input {
    position: absolute;
    inset: 0;
    opacity: 0;
    cursor: pointer;
    width: 100%;
    height: 100%;
  }

  .pod-upload-trigger {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    pointer-events: none;
  }

  .pod-upload-icon {
    color: var(--pod-gray);
    margin-bottom: 2px;
  }

  .pod-upload-main-text {
    font-size: 13px;
    font-weight: 600;
    color: var(--pod-dark);
  }

  .pod-upload-sub-text {
    font-size: 11px;
    color: var(--pod-gray);
  }

  /* FILE PREVIEW CARD */
  .pod-file-preview-card {
    display: flex;
    align-items: center;
    background-color: var(--pod-white);
    border: 1px solid var(--pod-border);
    border-radius: var(--pod-radius-sm);
    padding: 10px 14px;
    margin-top: 8px;
    gap: 12px;
    animation: slideDown 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  @keyframes slideDown {
    from { opacity: 0; transform: translateY(-8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .pod-file-preview-img {
    width: 40px;
    height: 40px;
    border-radius: 4px;
    object-fit: cover;
    border: 1px solid var(--pod-border);
  }

  .pod-file-preview-info {
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    overflow: hidden;
  }

  .pod-file-name {
    font-size: 12px;
    font-weight: 600;
    color: var(--pod-dark);
    white-space: nowrap;
    text-overflow: ellipsis;
    overflow: hidden;
  }

  .pod-file-size {
    font-size: 10px;
    color: var(--pod-gray);
  }

  .pod-file-remove-btn {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 14px;
    color: var(--pod-gray);
    padding: 4px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
  }

  .pod-file-remove-btn:hover {
    color: #ef4444;
    background-color: #fee2e2;
  }

  /* ACTIONS ROW (QUANTITY + BUTTON) */
  .pod-actions-row {
    display: flex;
    gap: 16px;
    margin-bottom: 24px;
  }

  .pod-quantity-selector {
    display: flex;
    align-items: center;
    border: 1.5px solid var(--pod-border);
    border-radius: var(--pod-radius-sm);
    height: 48px;
    background-color: var(--pod-white);
    overflow: hidden;
  }

  .pod-qty-btn {
    width: 38px;
    height: 100%;
    background: none;
    border: none;
    cursor: pointer;
    font-size: 16px;
    font-weight: 600;
    color: var(--pod-dark);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s ease;
  }

  .pod-qty-btn:hover {
    background-color: var(--pod-light);
  }

  .pod-qty-input {
    width: 36px;
    height: 100%;
    border: none;
    background: none;
    text-align: center;
    font-size: 14px;
    font-weight: 700;
    color: var(--pod-dark);
    -moz-appearance: textfield;
  }

  .pod-qty-input::-webkit-outer-spin-button,
  .pod-qty-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .pod-submit-btn {
    flex-grow: 1;
    height: 48px;
    background-color: var(--pod-primary);
    color: var(--pod-white);
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 0.5px;
    border: none;
    border-radius: var(--pod-radius-sm);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .pod-submit-btn:hover {
    background-color: var(--pod-primary-hover);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(79, 70, 229, 0.25);
  }

  .pod-submit-btn:active {
    transform: translateY(0);
  }

  .pod-btn-spinner {
    width: 18px;
    height: 18px;
    border: 2px solid var(--pod-white);
    border-top-color: transparent;
    border-radius: 50%;
    animation: rotateSpinner 0.8s linear infinite;
  }

  @keyframes rotateSpinner {
    to { transform: rotate(360deg); }
  }

  /* TRUST BADGES */
  .pod-badges-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 32px;
    border-top: 1px solid var(--pod-border);
    border-bottom: 1px solid var(--pod-border);
    padding: 16px 0;
  }

  @media (max-width: 768px) {
    .pod-badges-grid {
      grid-template-columns: 1fr;
      gap: 12px;
    }
  }

  .pod-badge-item {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .pod-badge-item svg {
    flex-shrink: 0;
  }

  .pod-badge-text-box {
    display: flex;
    flex-direction: column;
  }

  .pod-badge-title {
    font-size: 12px;
    font-weight: 700;
    color: var(--pod-dark);
  }

  .pod-badge-desc {
    font-size: 10px;
    color: var(--pod-gray);
  }

  /* TABS CONTAINER */
  .pod-tabs-container {
    border: 1px solid var(--pod-border);
    border-radius: var(--pod-radius-md);
    background-color: var(--pod-white);
    overflow: hidden;
  }

  .pod-tabs-header {
    display: flex;
    background-color: var(--pod-light);
    border-bottom: 1px solid var(--pod-border);
    overflow-x: auto;
  }

  .pod-tab-header-btn {
    flex-grow: 1;
    background: none;
    border: none;
    padding: 14px 20px;
    font-size: 12px;
    font-weight: 700;
    color: var(--pod-gray);
    cursor: pointer;
    text-align: center;
    transition: all 0.2s ease;
    white-space: nowrap;
    border-bottom: 2px solid transparent;
  }

  .pod-tab-header-btn:hover {
    color: var(--pod-dark);
  }

  .pod-tab-header-btn.active {
    color: var(--pod-primary);
    border-bottom-color: var(--pod-primary);
    background-color: var(--pod-white);
  }

  .pod-tabs-body {
    padding: 20px;
  }

  .pod-tab-content {
    display: none;
    animation: fadeIn 0.4s ease;
  }

  .pod-tab-content.active {
    display: block;
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .pod-info-list {
    margin: 0;
    padding-left: 20px;
    font-size: 13px;
    color: var(--pod-gray);
  }

  .pod-info-list li {
    margin-bottom: 8px;
  }

  .pod-info-list li:last-child {
    margin-bottom: 0;
  }

  .pod-tab-para {
    font-size: 13px;
    color: var(--pod-gray);
    margin: 0 0 12px 0;
  }

  .pod-tab-para:last-child {
    margin-bottom: 0;
  }

  /* SIZING TABLE */
  .pod-sizing-grid {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 24px;
    align-items: center;
  }

  @media (max-width: 576px) {
    .pod-sizing-grid {
      grid-template-columns: 1fr;
      justify-items: center;
    }
  }

  .pod-sizing-svg {
    opacity: 0.8;
  }

  .pod-sizing-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 12px;
    text-align: left;
  }

  .pod-sizing-table th, 
  .pod-sizing-table td {
    padding: 8px 12px;
    border-bottom: 1px solid var(--pod-border);
  }

  .pod-sizing-table th {
    font-weight: 700;
    color: var(--pod-dark);
    background-color: var(--pod-light);
  }

  .pod-sizing-table td {
    color: var(--pod-gray);
    font-weight: 500;
  }

  .pod-sizing-table tbody tr:hover td {
    background-color: var(--pod-light);
    color: var(--pod-dark);
  }
</style>

<script>
  // INTERACTION LOGIC FOR THE SHOPIFY POD SECTION
  document.addEventListener('DOMContentLoaded', function() {
    const sectionContainer = document.getElementById('PodSection-{{ section.id }}');
    if (!sectionContainer) return;

    // Gallery Thumbnail Switching
    const mainImage = sectionContainer.querySelector('#PodMainImage-{{ section.id }}');
    const thumbnailBtns = sectionContainer.querySelectorAll('.pod-thumbnail-btn');

    thumbnailBtns.forEach(btn => {
      btn.addEventListener('click', function() {
        thumbnailBtns.forEach(b => b.classList.remove('active'));
        this.classList.add('active');
        const newSrc = this.getAttribute('data-image-url');
        if (mainImage && newSrc) {
          mainImage.src = newSrc;
        }
      });
    });

    // Swatches Selection Logic
    const colorBtns = sectionContainer.querySelectorAll('.pod-swatch-btn');
    const selectedColorText = sectionContainer.querySelector('#SelectedColorText');

    colorBtns.forEach(btn => {
      btn.addEventListener('click', function() {
        colorBtns.forEach(b => b.classList.remove('active'));
        this.classList.add('active');
        const colorName = this.getAttribute('data-color');
        if (selectedColorText) {
          selectedColorText.textContent = colorName;
        }
        
        // Custom Hook: If matching variant images exist, you can change the main image here.
        // In real Shopify templates, you would parse the variant maps.
      });
    });

    // Size Selector Logic
    const sizePills = sectionContainer.querySelectorAll('.pod-size-pill');
    const selectedSizeText = sectionContainer.querySelector('#SelectedSizeText');

    sizePills.forEach(pill => {
      pill.addEventListener('click', function() {
        sizePills.forEach(p => p.classList.remove('active'));
        this.classList.add('active');
        const sizeName = this.getAttribute('data-size');
        if (selectedSizeText) {
          selectedSizeText.textContent = sizeName;
        }
      });
    });

    // Slogan Text Character Counter
    const sloganInput = sectionContainer.querySelector('#PersonalizationSlogan');
    const charCounter = sectionContainer.querySelector('#SloganCharCount');

    if (sloganInput && charCounter) {
      sloganInput.addEventListener('input', function() {
        const length = this.value.length;
        charCounter.textContent = `${length}/25`;
        
        if (length >= 25) {
          charCounter.style.color = '#ef4444'; // Red counter warning at max characters
        } else {
          charCounter.style.color = 'var(--pod-gray)';
        }
      });
    }

    // Photo File Upload with Preview and Remove
    const fileInput = sectionContainer.querySelector('#PersonalizationPhoto');
    const uploadContainer = sectionContainer.querySelector('#PodUploadContainer');
    const previewCard = sectionContainer.querySelector('#FilePreviewCard');
    const previewImg = sectionContainer.querySelector('#FilePreviewImage');
    const previewName = sectionContainer.querySelector('#FilePreviewName');
    const previewSize = sectionContainer.querySelector('#FilePreviewSize');
    const removeBtn = sectionContainer.querySelector('#RemoveFileBtn');

    if (fileInput) {
      fileInput.addEventListener('change', function() {
        const file = this.files[0];
        if (file) {
          // File size validation (10MB limit)
          if (file.size > 10 * 1024 * 1024) {
            alert('File size exceeds the 10MB limit. Please select a smaller image.');
            this.value = '';
            return;
          }

          // Show file details
          previewName.textContent = file.name;
          previewSize.textContent = (file.size / (1024 * 1024)).toFixed(2) + ' MB';

          // Load preview image
          const reader = new FileReader();
          reader.onload = function(e) {
            previewImg.src = e.target.result;
            uploadContainer.style.display = 'none';
            previewCard.style.display = 'flex';
          };
          reader.readAsDataURL(file);
        }
      });

      // Drag and drop events
      ['dragenter', 'dragover'].forEach(eventName => {
        uploadContainer.addEventListener(eventName, (e) => {
          e.preventDefault();
          uploadContainer.style.borderColor = 'var(--pod-primary)';
          uploadContainer.style.backgroundColor = 'var(--pod-light)';
        }, false);
      });

      ['dragleave', 'drop'].forEach(eventName => {
        uploadContainer.addEventListener(eventName, (e) => {
          e.preventDefault();
          uploadContainer.style.borderColor = 'var(--pod-border)';
          uploadContainer.style.backgroundColor = 'var(--pod-white)';
        }, false);
      });

      uploadContainer.addEventListener('drop', (e) => {
        const dt = e.dataTransfer;
        const files = dt.files;
        if (files.length > 0) {
          fileInput.files = files;
          fileInput.dispatchEvent(new Event('change'));
        }
      }, false);
    }

    if (removeBtn && fileInput) {
      removeBtn.addEventListener('click', function() {
        fileInput.value = ''; // Reset input
        previewCard.style.display = 'none';
        uploadContainer.style.display = 'block';
      });
    }

    // Quantity Selector Action
    const qtyInput = sectionContainer.querySelector('#PodQuantity');
    const qtyMinus = sectionContainer.querySelector('#QtyMinus');
    const qtyPlus = sectionContainer.querySelector('#QtyPlus');

    if (qtyInput) {
      qtyMinus.addEventListener('click', function() {
        let val = parseInt(qtyInput.value) || 1;
        if (val > 1) {
          qtyInput.value = val - 1;
        }
      });

      qtyPlus.addEventListener('click', function() {
        let val = parseInt(qtyInput.value) || 1;
        qtyInput.value = val + 1;
      });
    }

    // Tabs Content Switcher
    const tabBtns = sectionContainer.querySelectorAll('.pod-tab-header-btn');
    const tabContents = sectionContainer.querySelectorAll('.pod-tab-content');

    tabBtns.forEach(btn => {
      btn.addEventListener('click', function() {
        const tabTarget = this.getAttribute('data-tab');
        
        tabBtns.forEach(b => b.classList.remove('active'));
        tabContents.forEach(c => c.classList.remove('active'));

        this.classList.add('active');
        const targetContent = sectionContainer.querySelector(`#Tab-${tabTarget}`);
        if (targetContent) {
          targetContent.classList.add('active');
        }
      });
    });

    // Form Submit Intercept (Clean and minimal loading indication)
    const form = sectionContainer.querySelector('#PodProductForm');
    const submitBtn = sectionContainer.querySelector('#PodAddToCartBtn');
    const btnText = submitBtn ? submitBtn.querySelector('.pod-btn-text') : null;
    const btnSpinner = submitBtn ? submitBtn.querySelector('.pod-btn-spinner') : null;

    if (form && submitBtn) {
      form.addEventListener('submit', function(e) {
        // Simple client-side validation
        if (fileInput && fileInput.files.length === 0) {
          e.preventDefault(); // Stop form submission
          alert('Please upload a custom photo to personalize your hoodie.');
          return;
        }

        // Show loading state
        if (btnText && btnSpinner) {
          btnText.style.display = 'none';
          btnSpinner.style.display = 'inline-block';
          submitBtn.style.opacity = '0.8';
          submitBtn.style.pointerEvents = 'none';
        }
        
        // Proceed with normal Shopify form post (Add to cart action)
      });
    }
  });
</script>

